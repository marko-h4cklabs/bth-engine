# Anthropic (for AI Auditor step)
ANTHROPIC_API_KEY=

# Google Places API
GOOGLE_PLACES_API_KEY=

# Agency details (appear in PDF and landing page)
AGENCY_NAME=
AGENCY_DOMAIN=https://agencija.hr
CALENDLY_URL=https://calendly.com/yourlink

# Landing pages
DEPLOY_MODE=local   # local | vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Notifications (Telegram)
TELEGRAM_BOT_TOKEN=   # From @BotFather
TELEGRAM_CHAT_ID=     # Your chat/channel ID

# Tracker server (bridges landing page visits → Telegram; run with: pnpm tracker)
TRACKER_PORT=3456
TRACKER_URL=http://localhost:3456   # Public URL if server is exposed (ngrok, VPS, etc.)

# Output paths
OUTPUT_DIR=./output
